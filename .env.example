# ============================================================
# DATABASE
# ============================================================

DB_DSN=root:example_tour_password@tcp(catatan_mysql:3306)/catatan_app?parseTime=true
# → format: username:password@tcp(host:port)/nama_database?options
# → catatan_mysql = hostname database — ini nama container MySQL di docker-compose.yml

# ============================================================
# SERVER
# ============================================================

APP_ENV=production


APP_PORT=8080


# ============================================================
# CORS
# ============================================================

CORS_ALLOWED_ORIGINS=http://localhost

# ============================================================
# JWT
# ============================================================

JWT_SECRET=PLEASE_CHANGE_THIS_TO_A_RANDOM_SECRET

JWT_EXPIRED_HOURS=24
